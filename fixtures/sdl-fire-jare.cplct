paletteG[58] = 242
paletteB[58] = 0
paletteR[59] = 255
paletteG[59] = 242
paletteB[59] = 0
paletteR[60] = 255
paletteG[60] = 246
paletteB[60] = 0
paletteR[61] = 255
paletteG[61] = 250
paletteB[61] = 0
paletteR[62] = 255
paletteG[62] = 250
paletteB[62] = 0
paletteR[63] = 255
paletteG[63] = 255
paletteB[63] = 0
pi = 64
as pi < 256
  paletteR[pi] = 255
  paletteG[pi] = 255
  paletteB[pi] = 255
  pi = pi + 1
repeat

# --- Initialization ---
sdlInit
sdlWindow 640 400 "Fire Effect"
sdlRenderer

# --- Main fire tick ---
func fireTick frame backbuffer tempbuffer paletteR paletteG paletteB
  make width 80
  make height 50
  make dispW 640
  make dispH 400
  make bufSize 4000
  # Pre-declare all loop variables - alloca must not appear inside loops
  make y 0
  make x 0
  make idx 0
  make above 0
  make below 0
  make sum 0
  make avg 0
  make cool 0
  make si 0
  make heat 0
  make ry 0
  make rx 0
  make simY 0
  make x1 0
  make x2 0
  make cidx 0
  make color 0
  make r 0
  make g 0
  make b 0

  # Step 1: 8-neighbor average from backbuffer into tempbuffer
  # Original Jare 1993 algorithm: sum%4==0 (25% chance) applies cooling or wrap-around
  # Upper rows: cool non-zero pixels by 1; bottom 4 rows: zero pixels wrap to 255 (heat source)
  y = 1
  as y < height - 1
    x = 1
    as x < width - 1
      idx = y * width + x
      above = idx - width
      below = idx + width

      sum = backbuffer[above - 1]
      sum = sum + backbuffer[above]
      sum = sum + backbuffer[above + 1]
      sum = sum + backbuffer[idx - 1]
      sum = sum + backbuffer[idx + 1]
      sum = sum + backbuffer[below - 1]
      sum = sum + backbuffer[below]
      sum = sum + backbuffer[below + 1]
      avg = sum / 8
      cool = sum % 4
      if cool == 0
        if y <= height - 5
          if avg > 0
            avg = avg - 1
          endif
        endif
        if y > height - 5
          avg = avg + 255
          avg = avg % 256
        endif
      endif

      tempbuffer[idx] = avg
      x = x + 1
    repeat
    y = y + 1
  repeat

  # Step 2: Scroll - copy tempbuffer[row+1] into backbuffer[row]
  # backbuffer is set clean here before ash removal touches tempbuffer
  si = width
  as si < bufSize
    backbuffer[si - width] = tempbuffer[si]
    si = si + 1
  repeat

  # Step 3: Ash removal - cosmetic ember glow on tempbuffer only
  # Runs after scroll so these values never feed back into averaging
  # Values 0-14 in bottom 7 rows map to 22-value, matching original ASM/JS
  y = height - 7
  as y < height - 1
    x = 0
    as x < width
      idx = y * width + x
      heat = tempbuffer[idx]
      if heat <= 14
        avg = 22
        heat = avg - heat
        tempbuffer[idx] = heat
      endif
      x = x + 1
    repeat
    y = y + 1
  repeat

  # Step 4: Render tempbuffer scaled 8x to 640x400 display
  # Each sim pixel is one 8-pixel-wide horizontal line; 32000 draw calls vs 256000 before
  ry = 0
  as ry < dispH
    simY = ry / 8
    rx = 0
    as rx < width
      cidx = simY * width + rx
      color = tempbuffer[cidx]
      r = paletteR[color]
      g = paletteG[color]
      b = paletteB[color]
      sdlSetColor r g b
      x1 = rx * 8
      x2 = x1 + 7
      sdlDrawLine x1 ry x2 ry
      rx = rx + 1
    repeat
    ry = ry + 1
  repeat
end

# --- Main loop ---
make frame 0
as 1 == 1
  call fireTick frame backbuffer tempbuffer paletteR paletteG paletteB
  sdlPresent
  sdlDelay 16
  sdlEvents
  frame = frame + 1
repeat
