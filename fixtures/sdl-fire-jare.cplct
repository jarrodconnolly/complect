# Classic 2D Fire Effect
# Based on Javier "Jare" Arevalo's original 1993 ASM algorithm
# Two-buffer approach: compute tempbuffer from backbuffer, scroll up 1px per frame

# --- Configuration ---
# Simulation runs at original 80x50 resolution; display window is 640x400 (8x scale)
make width 80
make height 50
make bufSize 0
bufSize = width * height

# --- Frame buffers ---
make backbuffer[bufSize]
make tempbuffer[bufSize]

# --- Initialize buffers to zero ---
make i 0
as i < bufSize
  backbuffer[i] = 0
  tempbuffer[i] = 0
  i = i + 1
repeat

# --- Fire palette: index 0-255 maps to R,G,B ---
# Simplified palette: ramps from black through red/orange to yellow to white
make paletteR[256]
make paletteG[256]
make paletteB[256]

# Jare 1993 original hand-rolled palette - VGA values (0-63) scaled to 0-255
# Entries 0-5: black fading in with blue-green smoke tint
# Entries 6-11: smoke-to-dark-red transition
# Entries 12-63: red ramping through orange to yellow
# Entries 64-255: pure white (hot core)
make pi 0
paletteR[0] = 0
paletteG[0] = 0
paletteB[0] = 0
paletteR[1] = 0
paletteG[1] = 4
paletteB[1] = 4
paletteR[2] = 0
paletteG[2] = 16
paletteB[2] = 20
paletteR[3] = 0
paletteG[3] = 28
paletteB[3] = 36
paletteR[4] = 0
paletteG[4] = 32
paletteB[4] = 44
paletteR[5] = 0
paletteG[5] = 36
paletteB[5] = 48
